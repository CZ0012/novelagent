{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StoryGraph Agent",
  "version": "0.1.4",
  "identifier": "local.storygraph.agent",
  "build": {
    "beforeDevCommand": "npm --prefix ../web run dev",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "StoryGraph Agent",
        "width": 1440,
        "height": 1000,
        "minWidth": 1080,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/storygraph-backend"],
    "icon": ["icons/icon.ico"],
    "publisher": "StoryGraph Agent",
    "shortDescription": "StoryGraph Agent 桌面壳",
    "longDescription": "本地 StoryGraph Agent 写作台与 FastAPI 后端的桌面宿主。"
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5MTFBNzQ0MkI2QTY3NkQKUldSdFoyb3JSS2NSaVlRcWdzR3FFak1sU05rMHBBaGVHRllCcXROMWRzOVNLM1hudExuemg0UEcK",
      "endpoints": [
        "https://github.com/CZ0012/novelagent/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
