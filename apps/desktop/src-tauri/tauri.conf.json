{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StoryGraph Agent",
  "version": "0.1.0",
  "identifier": "local.storygraph.agent",
  "build": {
    "beforeDevCommand": "npm --prefix ../web run dev",
    "beforeBuildCommand": "npm --prefix ../web run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "StoryGraph Agent",
        "width": 1440,
        "height": 1000,
        "minWidth": 1080,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  }
}
